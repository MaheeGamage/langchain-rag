# Copy this file to .env and fill in the values.
# LLM_PROVIDER and EMBEDDING_PROVIDER are fully independent — mix any combination.

# ── Provider switches ─────────────────────────────────────────────────────────
# Supported: ollama | openai | gemini
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# ── ChromaDB (HTTP) ──────────────────────────────────────────────────────────
# Dev default: API/ingest on host + Chroma in Docker mapped to localhost:8001.
# In docker-compose api container, values are overridden to CHROMA_HOST=chroma, CHROMA_PORT=8000.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false

# ── Example: cheap local embeddings + cloud LLM ───────────────────────────────
# LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=ollama

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=tinyllama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_JUDGE_LLM_MODEL=phi3.5

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=   # optional: Azure / proxy endpoint

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-google-api-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Available google models
# 1. 'gemini-2.5-flash-lite'
# 2. 'gemma-3-27b-it'

# ── SQLite DB for conversation history (optional) ────────────────────────────────
CONVERSATIONS_DB=./local_db/conversations.db

# ── MLflow tracing (optional) ─────────────────────────────────────────────────
# Set MLFLOW_ENABLED=true to activate automatic LangChain / LangGraph tracing.
# Traces will be sent to the tracking server at MLFLOW_TRACKING_URI.
# Credentials are the standard MLflow env vars read natively by the library.
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=https://your-mlflow-server/
MLFLOW_EXPERIMENT_NAME=langchain-rag
MLFLOW_TRACKING_USERNAME=your-username
MLFLOW_TRACKING_PASSWORD=your-password